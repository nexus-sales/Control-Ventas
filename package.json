{
  "name": "control-ventas",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "echo 'Prettier not configured yet'",
    "format:check": "echo 'Prettier not configured yet'",
    "type-check": "echo 'Type checking not configured (JavaScript project)'",
    "validate": "npm run lint && npm run test",
    "healthcheck": "node -e \"import('./src/utils/healthcheck.js').then(m => m.healthcheck().then(console.log))\"",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "vercel:env": "vercel env add"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.95.3",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.34.0",
    "js-sha256": "^0.11.1",
    "lucide-react": "^0.544.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.4.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "hint": "^2.0.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.6",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^3.2.4"
  }
}
